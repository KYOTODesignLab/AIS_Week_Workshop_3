# Copy this file to .env and fill in your credentials.
# .env is listed in .gitignore — never commit the real file.
#
# How to get these values:
#   1. Go to https://developers.facebook.com/ → create an app (type: Business)
#   2. Add "Instagram Graph API" as a product
#   3. Connect your Instagram Professional (Business or Creator) account
#   4. Generate a long-lived User Access Token with permissions:
#        instagram_basic, instagram_content_publish
#   5. Find your numeric User ID:
#        GET https://graph.instagram.com/me?fields=id&access_token=<TOKEN>
#
# Optional: set PUBLIC_BASE_URL if this server is behind a public HTTPS tunnel
#   (e.g. ngrok). Instagram requires a publicly reachable URL to fetch the image.
#   If omitted, the server uses its local LAN IP (works only if Instagram can
#   reach your machine, e.g. via ngrok).

INSTAGRAM_ACCESS_TOKEN=your_long_lived_access_token
INSTAGRAM_USER_ID=your_numeric_instagram_user_id
PUBLIC_BASE_URL=https://your-ngrok-subdomain.ngrok.io
